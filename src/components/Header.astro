---
import { site } from "@/lib/site";

const navLinks = [
  { href: "#services", label: "What I do" },
  { href: "#process", label: "How it works" },
  { href: "#about", label: "About" },
  { href: "#contact", label: "Contact" },
];
---

<header class="rise rise-1 sticky top-0 z-40 border-b border-ink/10 bg-paper/85 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-baseline justify-between gap-6 px-6 py-5">
    <a href="#top" class="font-display text-xl tracking-tight">
      Darryl Morley
    </a>
    <nav class="hidden items-baseline gap-7 text-sm text-ink-soft sm:flex">
      {
        navLinks.map((link) => (
          <a href={link.href} class="transition-colors hover:text-ink">
            {link.label}
          </a>
        ))
      }
    </nav>
    {
      site.phone && site.phoneHref ? (
        <Fragment>
          <a
            href={site.phoneHref}
            class="hidden text-sm font-semibold text-moss transition-colors hover:text-moss-deep sm:inline"
          >
            {site.phone}
          </a>
          <a
            href="#contact"
            class="text-sm font-bold text-moss transition-colors hover:text-moss-deep sm:hidden"
          >
            Get in touch
          </a>
        </Fragment>
      ) : (
        <a
          href="#contact"
          class="text-sm font-bold text-moss transition-colors hover:text-moss-deep"
        >
          Get in touch
        </a>
      )
    }
  </div>
</header>
