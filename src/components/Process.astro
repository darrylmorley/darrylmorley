---
const steps = [
  {
    number: "1",
    title: "We talk",
    body: "A chat about what you need. Free, no obligation, plain English.",
  },
  {
    number: "2",
    title: "You get a fixed quote",
    body: "One price, written down. No surprises on the invoice.",
  },
  {
    number: "3",
    title: "I build it",
    body: "You see progress as it happens, not a big reveal at the end.",
  },
  {
    number: "4",
    title: "I stick around",
    body: "Launch isn't the end. Updates, fixes and advice when you need them.",
  },
];
---

<section id="process" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-20 sm:py-28">
  <h2 class="reveal font-mono text-xs tracking-[0.2em] text-moss uppercase">
    How it works
  </h2>
  <div class="mt-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    {
      steps.map((step, index) => (
        <div class="reveal">
          <div class="flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full border border-moss font-display text-lg text-moss">
              {step.number}
            </span>
            {index < steps.length - 1 && (
              <span
                class="hidden flex-1 border-t border-dashed border-moss/30 lg:block"
                aria-hidden="true"
              />
            )}
          </div>
          <h3 class="mt-5 font-display text-xl tracking-tight">
            {step.title}
          </h3>
          <p class="mt-3 leading-relaxed text-ink-soft">{step.body}</p>
        </div>
      ))
    }
  </div>
</section>
