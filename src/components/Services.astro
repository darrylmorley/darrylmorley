---
const services = [
  {
    number: "01",
    title: "Websites & online shops",
    body: "Web design done properly: quick to load, easy to update, found on Google. Not bolted together with a page builder and hope.",
  },
  {
    number: "02",
    title: "Systems that talk to each other",
    body: "Your till, stock, bookings and website, all in sync. The unglamorous plumbing that saves you hours every week.",
  },
  {
    number: "03",
    title: "Getting found on Google",
    body: "Technical SEO: speed, structure and local search. No jargon, and no monthly report full of graphs that mean nothing.",
  },
  {
    number: "04",
    title: "Rescue & upkeep",
    body: "Agency built it then vanished? I'll take it on, fix what's broken and keep it running.",
  },
];
---

<section id="services" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-20 sm:py-28">
  <h2 class="reveal font-mono text-xs tracking-[0.2em] text-moss uppercase">
    What I do
  </h2>
  <div class="mt-10 grid border-t border-ink/15 sm:grid-cols-2">
    {
      services.map((service) => (
        <article class="reveal group border-b border-ink/15 py-10 transition-colors hover:bg-paper-deep/50 sm:px-8 sm:first:pl-0 sm:nth-[2n]:border-l sm:nth-[2n+1]:pl-0 sm:last:pr-0">
          <span class="font-mono text-sm text-stone transition-colors group-hover:text-moss">
            {service.number}
          </span>
          <h3 class="mt-3 font-display text-2xl tracking-tight sm:text-3xl">
            {service.title}
          </h3>
          <p class="mt-4 max-w-md leading-relaxed text-ink-soft">
            {service.body}
          </p>
        </article>
      ))
    }
  </div>
</section>
